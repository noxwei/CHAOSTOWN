# CHAOSTOWN Environment Configuration
# Copy this file to .env and modify as needed

# API Configuration
API_PORT=8000
API_HOST=0.0.0.0

# Database Configuration
POSTGRES_HOST=db
POSTGRES_PORT=5432
POSTGRES_DB=chaostown
POSTGRES_USER=postgres
POSTGRES_PASSWORD=chaostown_password

# Simulation Configuration
SIMULATION_TICK_RATE=1.0
MAX_AGENTS=100
INITIAL_AGENT_COUNT=10

# AI Models Configuration
OPENAI_API_KEY=your_openai_api_key_here
OLLAMA_HOST=ollama
OLLAMA_PORT=11434

# Dashboard Configuration
DASHBOARD_PORT=3000
GRAFANA_PORT=3000

# Cat Happiness Configuration (CRITICAL)
MIN_CAT_HAPPINESS=0.8
CAT_PHOTO_REQUIRED=true
EMERGENCY_CAT_PROTOCOL=enabled

# Logging
LOG_LEVEL=INFO
METRICS_ENABLED=true

# Storage
MEDIA_STORAGE_PATH=/app/media
BACKUP_SCHEDULE=0 2 * * *